# ForgeGravity API Keys
# Copy this file to .env and fill in your API keys.
# At least one provider is required.

# OpenAI
FORGE_OPENAI_API_KEY=

# Anthropic
FORGE_ANTHROPIC_API_KEY=

# Google Gemini
FORGE_GEMINI_API_KEY=

# OpenRouter
FORGE_OPENROUTER_API_KEY=

# Ollama (no key needed, just the base URL)
FORGE_OLLAMA_BASE_URL=http://localhost:11434
